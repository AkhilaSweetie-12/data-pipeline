# Copy to .env and adjust. In production these values come from Azure Key Vault.
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT auth (override JWT_SECRET in production - source from Key Vault)
JWT_SECRET=dev-only-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Default DEV users (username:password:role). Remove/override in production.
SEED_USERS=admin:admin123:admin,engineer:engineer123:data_engineer,analyst:analyst123:analyst

# DEV default (SQLite, zero-config):
DATABASE_URL=sqlite:///./retail_dev.db

# Azure SQL example (uncomment and fill in):
# DATABASE_URL=mssql+pyodbc://<user>:<password>@<server>.database.windows.net:1433/retail?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
